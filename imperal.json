        "properties": {
          "case_id": {
            "title": "Case Id",
            "type": "integer"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "run_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Run Id"
          },
          "version": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Version"
          }
        },
        "required": [
          "case_id",
          "status"
        ],
        "title": "RunAnalysisResponse",
        "type": "object"
      },
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_sharelock_chat"
