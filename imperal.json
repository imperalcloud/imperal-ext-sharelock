    {
      "name": "review_analysis_gaps",
      "description": "Review gaps found during analysis",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "case_id": {
            "description": "Case ID",
            "title": "Case Id",
            "type": "integer"
          }
        },
        "required": [
          "case_id"
        ],
        "title": "CaseIdParams",
        "type": "object"
      },
      "return_schema": {
        "$defs": {
          "GapReviewItem": {
            "description": "One row from review_analysis_gaps.data[\"gaps\"][] / .data[\"by_severity\"][sev][].\n\nFields observed in handlers_analysis.py:122-145 — severity comes from\nCases API gap rows (BLOCKING/QUALITY/INFORMATIONAL); description is the\nfirst line of the gap's full description.\n\nSDL: a single analysis gap. Canonical id <- existing ``id``; title <-\n``description``. NOTE deliberately NOT mixing ``sdl.Prioritized``: its\n``severity`` is a fixed Literal['info','minor','major','critical'] that\nwould reject Sharelock's BLOCKING/QUALITY/INFORMATIONAL values — keeping\nthe existing free-string ``severity`` preserves back-compat.",
            "properties": {
              "id": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "integer"
                  }
                ],
                "title": "Id"
              },
              "title": {
                "title": "Title",
                "type": "string"
              },
              "kind": {
                "default": "gap",
                "title": "Kind",
                "type": "string"
              },
              "subtitle": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Subtitle"
              },
              "description": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Description"
              },
              "status": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Status"
              },
              "url": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Url"
              },
              "severity": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Severity"
              }
            },
            "required": [
              "id",
              "title"
            ],
            "title": "GapReviewItem",
            "type": "object",
            "x-sdl": "entity"
          }
        },
        "description": "Envelope returned by review_analysis_gaps — describes the full `data` dict.\n\nHandlers_analysis.py:152-161: full structure with case_id/run_id +\nflat gaps list + by_severity bucket dict + confidence_*.",
        "properties": {
          "case_id": {
            "title": "Case Id",
            "type": "integer"
          },
          "run_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Run Id"
          },
          "gaps": {
            "default": [],
            "items": {
              "$ref": "#/$defs/GapReviewItem"
            },
            "title": "Gaps",
            "type": "array"
          },
          "by_severity": {
