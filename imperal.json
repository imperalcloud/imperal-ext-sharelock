{
  "manifest_schema_version": 3,
  "sdk_version": "5.2.0",
  "app_id": "sharelock-v2",
  "version": "3.3.0",
  "name": "Sharelock",
  "description": "Forensic case analysis — manage cases, upload documents, run AI-driven incremental analysis pipelines, generate prosecution and inspection reports, and review forensic findings.",
  "icon": "icon.svg",
  "actions_explicit": true,
  "system": false,
  "capabilities": [
    "sharelock:cases:read",
    "sharelock:cases:write",
    "sharelock:analysis:run",
    "sharelock:analysis:cancel",
    "sharelock:reports:read",
    "sharelock:reports:write",
    "storage:read",
    "storage:write",
    "store:read",
    "store:write",
    "config:read",
    "config:write",
    "ai:complete",
    "notify:push"
  ],
  "tools": [
    {
      "name": "skeleton_refresh_case_status",
      "description": "Sharelock case roster + active-case snapshot for classifier.",
      "scopes": [],
      "parameters": {
        "kwargs": {
          "type": "string",
          "required": true
        }
      }
    },
    {
      "name": "skeleton_alert_case_status",
      "description": "Skeleton alert",
      "scopes": [],
      "parameters": {
        "kwargs": {
          "type": "string",
          "required": true
        }
      }
    },
    {
      "name": "case_chat",
      "description": "Chat about a forensic investigation case. CRITICAL: pass the user's message VERBATIM in the `message` parameter — preserve case names, ids, and original language exactly. Do NOT paraphrase, translate, or summarize.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "message": {
            "default": "",
            "description": "User's VERBATIM message about the case. Pass EXACTLY as user typed — preserve case names ('Test Files', 'Alex Case 1'), case ids ('#3812', 'дело 17'), and original language (RU/EN). The handler does deterministic case-name and id matching against this string; paraphrasing or translating breaks resolution and silently drops the user into the case-list fallback.",
            "title": "Message",
            "type": "string"
          }
        },
        "title": "CaseChatParams",
        "type": "object"
      },
      "return_schema": {
        "description": "case_chat envelope — single `state` discriminator field.\n\nUsed as data_model= on the conversational catch-all handler. Note:\ncase_chat stays chain_callable=False (Task 5) because it consumes\nctx.history — typed dispatch drops history. data_model declaration is\nfor V23 compliance only; runtime path is the wrapper-LLM flow.",
        "properties": {
          "state": {
            "title": "State",
            "type": "string"
          }
        },
        "required": [
          "state"
        ],
        "title": "CaseChatResponse",
        "type": "object"
      },
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_sharelock_chat"
    },
    {
      "name": "create_case",
      "description": "Create a new investigation case. CRITICAL: pass user-supplied `name` and `description` VERBATIM in the original language (RU/EN). Do NOT paraphrase, translate, sanitise, or auto-title. Federal anti-hallucination invariant I-CHAT-FUNCTION-VERBATIM-PARAMS applies — rephrased input silently breaks dedupe.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "create:case",
        "create:folder"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "name": {
            "description": "Name for the new investigation case. CRITICAL: pass VERBATIM as the user typed it — preserve exact wording, capitalisation, and original language (RU/EN). Do NOT paraphrase, translate, sanitise, or auto-title. Downstream validation enforces uniqueness against the user's exact string; rephrased names silently create duplicates.",
            "title": "Name",
            "type": "string"
          },
          "description": {
            "default": "",
            "description": "Case description. CRITICAL: pass VERBATIM in the user's original language. Do NOT paraphrase, translate, or expand. Empty string if the user did not provide one.",
            "title": "Description",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "title": "CreateCaseParams",
        "type": "object"
      },
      "return_schema": {
        "description": "create_case success envelope. handlers.py: data={\"case_id\", \"name\"}.\n\n`case_id` is the Cases API id (int); the handler falls back to the\nstring \"?\" only when the API omits an id — hence ``int | str``.",
        "properties": {
          "case_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ],
            "title": "Case Id"
          },
          "name": {
            "title": "Name",
            "type": "string"
          }
        },
        "required": [
          "case_id",
          "name"
        ],
        "title": "CreateCaseResponse",
        "type": "object"
      },
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_sharelock_chat"
    },
    {
      "name": "sync_cases",
      "description": "Sync cases from Nextcloud folders — create cases for new folders",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "create:case"
      ],
      "id_projection": "",
      "params_schema": {
        "description": "Federal V17 placeholder for handlers that take no parameters.\n\n`@chat.function` MUST declare a Pydantic params model — this is the\ncanonical empty model reused by read-only handlers (list_*, sync_*,\n*_health) that don't need any input.",
        "properties": {},
        "title": "EmptyParams",
        "type": "object"
      },
      "return_schema": {
        "description": "sync_cases success envelope.\n\nhandlers.py: data={\"created\", \"skipped\", \"total_folders\"} — `created`\nand `skipped` are Nextcloud folder names; `total_folders` is the scan size.",
        "properties": {
          "created": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Created",
            "type": "array"
          },
          "skipped": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Skipped",
            "type": "array"
          },
          "total_folders": {
            "default": 0,
            "title": "Total Folders",
            "type": "integer"
          }
        },
        "title": "SyncCasesResponse",
        "type": "object"
      },
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_sharelock_chat"
    },
    {
      "name": "list_cases",
      "description": "List all investigation cases",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "Federal V17 placeholder for handlers that take no parameters.\n\n`@chat.function` MUST declare a Pydantic params model — this is the\ncanonical empty model reused by read-only handlers (list_*, sync_*,\n*_health) that don't need any input.",
        "properties": {},
        "title": "EmptyParams",
        "type": "object"
      },
      "return_schema": {
        "$defs": {
          "CaseRecord": {
            "description": "One row from list_cases.data[\"cases\"][] / case-summary lookups.\n\nMirrors the dict shape produced by handlers.py:117-122 and\nhandlers.py:367-369. Cases API may return either `status` or\n`analysis_status` (the handler does `c.get(\"analysis_status\") or\nc.get(\"status\")` — both are present in different code paths).\n\nSDL: a forensic investigation case → ``sdl.Caseable`` (sec.case_*).\nCanonical id <- existing ``id``; title <- existing ``name``.",
            "properties": {
              "case_number": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Case Number",
                "x-sdl-role": "sec.case_number"
              },
              "case_type": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Case Type",
                "x-sdl-role": "sec.case_type"
              },
              "case_stage": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Case Stage",
                "x-sdl-role": "sec.case_stage"
              },
              "opened_at": {
                "anyOf": [
                  {
                    "format": "date-time",
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Opened At",
                "x-sdl-role": "sec.opened_at"
              },
              "closed_at": {
                "anyOf": [
                  {
                    "format": "date-time",
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Closed At",
                "x-sdl-role": "sec.closed_at"
              },
              "case_resolution": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Case Resolution",
                "x-sdl-role": "sec.case_resolution"
              },
              "jurisdiction": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Jurisdiction",
                "x-sdl-role": "sec.jurisdiction"
              },
              "id": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "integer"
                  }
                ],
                "title": "Id"
              },
              "title": {
                "title": "Title",
                "type": "string"
              },
              "kind": {
                "default": "case",
                "title": "Kind",
                "type": "string"
              },
              "subtitle": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Subtitle"
              },
              "description": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Description"
              },
              "status": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Status"
              },
              "url": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
