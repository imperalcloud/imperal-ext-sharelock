            ],
            "title": "CaseRecord",
            "type": "object",
            "x-sdl": "entity"
          }
        },
        "description": "Envelope returned by list_cases — describes the full `data` dict.\n\nHandlers.py:371-374: `data={\"cases\": cases, \"count\": len(cases)}`.",
        "properties": {
          "cases": {
            "items": {
              "$ref": "#/$defs/CaseRecord"
