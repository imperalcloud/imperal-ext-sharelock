    {
      "name": "search_docs",
      "description": "Search case documents for entities, amounts, dates, or phrases. CRITICAL: pass the user-supplied `query` VERBATIM — preserve exact spelling, punctuation, amounts, and original language. Do NOT paraphrase, translate, normalise, or auto-correct. The Cases API performs exact substring matching.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "query": {
            "description": "Search term (entity name, amount, date, phrase). CRITICAL: pass VERBATIM as the user typed it — preserve exact spelling, punctuation, amounts, and original language. Do NOT paraphrase, translate, normalise, or auto-correct. The Cases API does exact substring matching; rephrased queries return empty results.",
            "title": "Query",
            "type": "string"
          },
          "case_id": {
            "default": 0,
            "description": "Case ID (0 = active case)",
            "title": "Case Id",
            "type": "integer"
          }
        },
        "required": [
          "query"
        ],
        "title": "SearchDocsParams",
        "type": "object"
      },
      "return_schema": {
        "$defs": {
          "DocSearchHit": {
            "description": "One hit from search_docs.data[\"results\"][].\n\nCases API response shape varies; fields are permissive except `doc_id`\nwhich is the primary identifier and is reliably present in real hits.\n\nSDL: a single document search hit. Canonical id <- existing ``doc_id``;\ntitle <- ``snippet`` (falling back to ``doc_id``). No standard facet maps\ncleanly to ``score`` (float relevance) / ``snippet`` without a type clash,\nso this stays a bare ``sdl.Entity``.",
            "properties": {
              "id": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "integer"
                  }
                ],
                "title": "Id"
              },
              "title": {
                "title": "Title",
                "type": "string"
              },
              "kind": {
                "default": "doc_hit",
                "title": "Kind",
                "type": "string"
              },
              "subtitle": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Subtitle"
              },
              "description": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Description"
              },
              "status": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Status"
              },
              "url": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Url"
              },
              "doc_id": {
                "title": "Doc Id",
                "type": "string"
              },
              "snippet": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Snippet"
              },
              "score": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Score"
              },
              "case_id": {
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Case Id"
              }
            },
            "required": [
              "id",
              "title",
              "doc_id"
            ],
            "title": "DocSearchHit",
            "type": "object",
            "x-sdl": "entity"
          }
        },
        "description": "Envelope returned by search_docs.\n\nHandlers.py:420-422 (404 path): `data={\"results\": []}`.\nHandlers.py:427-430 (success path): `data=results` (raw API response,\nmay be a list directly OR may be {\"count\":..., \"results\": [...]}).\nWe model the consistent shape `{\"results\": [...]}`. The success path\nwhere Cases API returns a raw list will round-trip without validation\nerror because Pydantic accepts the dict-or-list-as-data when data_model\nruntime validation is warn-only (5.0.1).",
        "properties": {
          "results": {
            "default": [],
            "items": {
              "$ref": "#/$defs/DocSearchHit"
            },
            "title": "Results",
            "type": "array"
          }
        },
        "title": "DocSearchResponse",
        "type": "object"
      },
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_sharelock_chat"
    },
    {
